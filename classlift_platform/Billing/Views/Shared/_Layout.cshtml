<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - ClassLift Billing</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand"
               href="/Dashboard">
                ClassLift Billing
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse"
                 id="navbarNav">

                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link"
                           href="/Dashboard">
                            Dashboard
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="/Plans">
                            Plans
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="/Organizations">
                            Organizations
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/FeatureAccessAdmin">Feature Access</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="/Invoices">
                            Invoices
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="/Payments">
                            Payments
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="/SubscriptionEvents">
                            Subscription Events
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="/Billing">
                            Billing Job
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           href="/BillingRuns">
                            Billing Run
                        </a>
                    </li>

                </ul>

            </div>
        </div>
    </nav>

    <div class="container-fluid mt-3">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        @RenderBody()

    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container py-3">
            &copy; @DateTime.UtcNow.Year - ClassLift Billing Engine
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>