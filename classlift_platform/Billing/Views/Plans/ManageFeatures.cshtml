@model Billing.ViewModels.ManagePlanFeaturesViewModel

@{
    ViewData["Title"] = "Manage Plan Features";
}

<div class="container mt-4">
    <h2>Manage Features - @Model.PlanName</h2>

    <form action="/Plans/ManageFeatures/@Model.PlanId" method="post" class="mt-3">

        <input type="hidden" asp-for="PlanId" />
        <input type="hidden" asp-for="PlanName" />

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Enabled</th>
                    <th>Required</th>
                    <th>Feature</th>
                    <th>Feature Key</th>
                </tr>
            </thead>

            <tbody>
                @for (int i = 0; i < Model.Features.Count; i++)
                {
                    <tr>
                        <td>
                            <input type="hidden" asp-for="Features[i].FeatureId" />
                            <input type="hidden" asp-for="Features[i].FeatureKey" />
                            <input type="hidden" asp-for="Features[i].FeatureName" />
                            <input type="hidden" asp-for="Features[i].IsLocked" />

                            <input asp-for="Features[i].IsSelected"
                                   class="form-check-input"
                                   disabled="@(Model.Features[i].IsLocked)" />
                        </td>
                        <td>
                            @if (Model.Features[i].IsLocked)
                            {
                                @* <span class="badge bg-secondary">✓</span> *@
                                <input asp-for="Features[i].IsLocked" class="form-check-input" disabled />
                            }
                        </td>

                        <td>@Model.Features[i].FeatureName</td>
                        <td>@Model.Features[i].FeatureKey</td>
                    </tr>
                }
            </tbody>
        </table>

        <button type="submit" class="btn btn-primary">
            Save Features
        </button>

        <a class="btn btn-secondary" href="/Plans/Details/@Model.PlanId">
            Cancel
        </a>
    </form>
</div>