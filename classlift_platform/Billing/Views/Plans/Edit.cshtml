@model Billing.Models.Subscriptionplan

@{
    ViewData["Title"] = "Edit Plan";
}

<div class="container mt-4">
    <h2>Edit Plan</h2>

    <form action="/Plans/Edit/@Model.PlanId" method="post" class="mt-3">
        <input type="hidden" asp-for="PlanId" />

        <div class="mb-3">
            <label asp-for="PlanName" class="form-label"></label>
            <input asp-for="PlanName" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="PricePerCoach" class="form-label"></label>
            <input asp-for="PricePerCoach" class="form-control" type="number" step="0.01" />
        </div>

        <div class="mb-3">
            <label asp-for="MinimumMonthlyPrice" class="form-label"></label>
            <input asp-for="MinimumMonthlyPrice" class="form-control" type="number" step="0.01" />
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>

        <button type="submit" class="btn btn-primary">
            Save
        </button>

        <a class="btn btn-secondary" href="/Plans/Details/@Model.PlanId">
            Cancel
        </a>
    </form>
</div>