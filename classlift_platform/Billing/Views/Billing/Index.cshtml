@{
    ViewData["Title"] = "Billing Administration";
}

<div class="container py-4">

    <div class="mb-4">
        <h2 class="fw-bold">Billing Administration</h2>
        <p class="text-muted">
            Run billing maintenance jobs manually when required.
        </p>
    </div>

    <div class="row g-4">

        <!-- Daily Job -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <h5 class="card-title">

                        Daily Billing Job
                    </h5>

                   

                    <form asp-controller="Billing" asp-action="RunDailyJob" method="post">
                        <button type="submit" class="btn btn-primary">

                            Run Daily Job
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Monthly Job -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <h5 class="card-title">
                        Monthly Billing Job
                    </h5>

                   

                    <form asp-controller="Billing" asp-action="RunMonthlyJob" method="post">
                        <button type="submit" class="btn btn-success">
                            Run Monthly Job
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>

</div>