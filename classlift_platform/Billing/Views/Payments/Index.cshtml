@model IEnumerable<Billing.Models.Payment>

@{
    ViewData["Title"] = "Payments";
}

<div class="container mt-4">
    <h2>Payments</h2>

    <table class="table table-bordered table-striped mt-3">
        <thead>
            <tr>
                <th>Payment ID</th>
                <th>Invoice ID</th>
                <th>Organization</th>
                <th>Provider</th>
                <th>Transaction ID</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Payment Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var payment in Model)
            {
                <tr>
                    <td>@payment.PaymentId</td>
                    <td>@payment.InvoiceId</td>
                    <td>@payment.Invoice?.Organization?.OrganizationName</td>
                    <td>@payment.PaymentProvider</td>
                    <td>@payment.ProviderTransactionId</td>
                    <td>@payment.Amount.ToString("C")</td>
                    <td>@payment.PaymentStatus</td>
                    <td>@payment.PaymentDate.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <a class="btn btn-sm btn-primary"
                           href="/Payments/Details/@payment.PaymentId">
                            Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
